#!/bin/bash

set -e
BOLD='tput bold'
UNBOLD='tput sgr0'

usage()
{
cat << EOF

usage: $($BOLD)$(basename $0)$($UNBOLD) options

This script launches or manages vimide within a tmux environment.

1. The script begins by launching a tmux session with a window labeled 'code', where VimIDE is executed in the top pane.
2. The bottom pane, labeled 'console', hosts a bash shell for interactive command-line tasks.

VimIDE Interactive Commands (to be used in the top pane, in Vim's visual mode):

- '\\ss': Opens an IPython console in the bottom pane that is directly linked to the active Vim instance.
- '\\\aa': Executes the selected lines of code from the top pane in the IPython console.
- '\\xx': Clears the IPython console, providing a clean slate.
- '\\ll': Runs the code cell in the top pane, defined by bounds marked with '# %%'.
- '\\dd': Initiates the debugger (pdb) on the current script in the top pane within the IPython console.
- '\\\rr': Executes the entire current script in the top pane using the IPython console.


OPTIONS:
    $($BOLD)-n, --name NAME$($UNBOLD)   Open a tmux session with the specified NAME. If the session does not exist, it will be created.
    $($BOLD)-q, --quit NAME$($UNBOLD)   Terminate the specified tmux session.
    $($BOLD)-l, --list$($UNBOLD)        Display a list of all active tmux sessions.
    $($BOLD)-d, --dir DIR$($UNBOLD)     Specify the working directory for the session. Defaults to the directory where $(basename "$0") is executed if not provided.
    $($BOLD)-h, --help$($UNBOLD)        Display this help message and exit.
EOF
}

NAME=
CWD=$(realpath .)
CDIR=$CWD
LIST=false
QUIT=false

# getopt
GOTEMP="$(getopt -o "n:q:ld:h" -l "name:,quit:,list,dir:,help"  -n '' -- "$@")"

if ! [ "$(echo -n $GOTEMP |sed -e"s/\-\-.*$//")" ]; then
    echo -En "$(usage)"; exit;
fi

eval set -- "$GOTEMP"


while true ;
do
    case "$1" in
        -n | --name)
            NAME="vide_$2"
            shift 2;;
        -q | --quit)
            NAME="vide_$2"
            QUIT=true
            shift 2;;
        -l | --list)
            LIST=true
            shift;
            break;;
        -d | --dir)
            CWD="$2"
            shift 2;;
        -h | --help)
            echo -e "$(usage)"; exit;
            shift;
            break;;
        --) shift;
            break;;
    esac
done

if [[ "$LIST" == true ]]; then
    tmux ls 2>/dev/null | grep "^vide_" \
        | sed -e "s/^vide_\([A-Za-z0-9]\+\):.*attached.*/\1 Attached/" \
              -e "s/^vide_\([A-Za-z0-9]\+\):.*/\1 Detached/"
    exit 0
fi


if [[ -z "$NAME" ]]; then
    echo "Must give a name to the session"
    exit 1
fi

cd "$CWD"


if [[ "$QUIT" == true ]]; then
    echo "Quitting $(echo $NAME | sed -e"s/vide_//g")..."
    tmux kill-session -t "$NAME"
    echo done
    exit 0
fi

# Create a new detached tmux session if one does not already exist.
# The 'code' window is split into two panes: top (vim) and bottom (console).
if ! tmux has-session -t "$NAME" 2>/dev/null; then
    tmux new-session -d -s "$NAME" -n code
    tmux split-window -v -t "$NAME:code" -l "25%"
fi

# Run vimide in the top pane (pane 0) if vim is not already running
if ! tmux list-panes -t "$NAME:code" -F '#{pane_current_command}' | grep -q vim; then
    tmux send-keys -t "$NAME:code.0" "vim ." Enter
    sleep 0.2
    tmux send-keys -t "$NAME:code.0" ":call RunPyIDE()" Enter
    sleep 0.1
    tmux send-keys -t "$NAME:code.0" ":let b:slime_config={'socket_name':'default', 'target_pane':'${NAME}:code.1'}" Enter
    sleep 0.1
    tmux send-keys -t "$NAME:code.0" ":au BufRead *.py let b:slime_config={'socket_name':'default', 'target_pane':'${NAME}:code.1'}" Enter
    sleep 0.1
    tmux send-keys -t "$NAME:code.0" ":silent call system('reset')" Enter
    sleep 0.01
    tmux send-keys -t "$NAME:code.1" "reset" Enter
fi

echo -ne "\033]0; $(hostname -I | awk '{print $1}'): $(echo "$NAME" | sed -e's/vide_//') \a"
tmux select-pane -t "$NAME:code.0"
tmux attach-session -t "$NAME"
