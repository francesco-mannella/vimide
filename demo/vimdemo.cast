[6.156392, "o", "\u001b[H\u001b[97m\u001b[40m \u001b[7m|\u001b[m\u000f\u001b[38;5;32m\u001b[48;5;234m  1 \u001b[38;5;207m\u001b[40m\u001b[1mimport\u001b[m\u000f\u001b[97m\u001b[40m time\u001b[90C \u001b[7m|\r\n\u001b[m\u000f\u001b[97m\u001b[40m \u001b[7m|\u001b[m\u000f\u001b[38;5;32m\u001b[48;5;234m  2 \u001b[38;5;207m\u001b[40m\u001b[1mimport\u001b[m\u000f\u001b[97m\u001b[40m torch\u001b[89C \u001b[7m|\r\n\u001b[m\u000f\u001b[97m\u001b[40m \u001b[7m|\u001b[m\u000f\u001b[38;5;32m\u001b[48;5;234m  3 \u001b[38;5;207m\u001b[40m\u001b[1mimport\u001b[m\u000f\u001b[97m\u001b[40m torch.nn  \u001b[93m\u001b[1mas\u001b[m\u000f\u001b[97m\u001b[40m  nn\u001b[78C \u001b[7m|\r\n\u001b[m\u000f\u001b[97m\u001b[40m \u001b[7m|\u001b[m\u000f\u001b[38;5;32m\u001b[48;5;234m  4 \u001b[101C\u001b[97m\u001b[40m \u001b[7m|\r\n\u001b[m\u000f\u001b[38;5;165m\u001b[40mL\u001b[97m\u001b[7m|\u001b[m\u000f\u001b[38;5;32m\u001b[48;5;234m  5 \u001b[101C\u001b[97m\u001b[40m \u001b[7m|\r\n\u001b[m\u000f\u001b[92m\u001b[40m+\u001b[97m\u001b[7m|\u001b[m\u000f\u001b[38;5;32m\u001b[48;5;234m  6 \u001b[101C\u001b[97m\u001b[40m \u001b[7m|\r\n\u001b[m\u000f\u001b[92m\u001b[40m+\u001b[97m\u001b[7m|\u001b[m\u000f\u001b[38;5;32m\u001b[48;5;234m  7 \u001b[93m\u001b[40m\u001b[1mdef\u001b[m\u000f\u001b[97m\u001b[40m \u001b[96m\u001b[1mmake_moons\u001b[m\u000f\u001b[97m\u001b[40m(n=\u001b[38;5;217m\u001b[48;5;234m400\u001b[97m\u001b[40m, noise=\u001b[38;5;217m\u001b[48;5;234m0.2\u001b[97m\u001b[40m):\u001b[68C \u001b[7m|\r\n\u001b[m\u000f\u001b[97m\u001b[40m \u001b[7m|\u001b[m\u000f\u001b[38;5;32m\u001b[48;5;234m  8 \u001b[97m\u001b[48;5;236m \u001b[40m   n2  =  n // \u001b[38;5;217m\u001b[48;5;234m2\u001b[84C\u001b[97m\u001b[40m \u001b[7m|\r\n\u001b[m\u000f\u001b[97m\u001b[40ma\u001b[7m|\u001b[m\u000f\u001b[38;5;32m\u001b[48;5;234m  9 \u001b[97m\u001b[48;5;236m \u001b[40m   t = torch.linspace(\u001b[38;5;217m\u001b[48;5;234m0\u001b[97m\u001b[40m, \u001b[38;5;217m\u001b[48;5;234m3.14159\u001b[97m\u001b[40m, n2)\u