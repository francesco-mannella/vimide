[6.157718, "o", "\u001b[44C\u001b[97m\u001b[40m \u001b[7m|\u001b[11;3H\u001b[m\u000f\u001b[38;5;32m\u001b[48;5;234m 11 \u001b[97m\u001b[48;5;236m \u001b[40m   x2 = torch.stack([\u001b[38;5;217m\u001b[48;5;234m1\u001b[97m\u001b[40m - torch.cos(t), \u001b[38;5;217m\u001b[48;5;234m1\u001b[97m\u001b[40m - torch.sin(t) - \u001b[38;5;217m\u001b[48;5;234m0.5\u001b[97m\u001b[40m], dim=\u001b[38;5;217m\u001b[48;5;234m1\u001b[97m\u001b[40m)\u001b[30C \u001b[7m|\u001b[12;3H\u001b[m\u000f\u001b[38;5;32m\u001b[48;5;234m 12 \u001b[97m\u001b[48;5;236m \u001b[40m   X = torch.cat([x1, x2], dim=\u001b[38;5;217m\u001b[48;5;234m0\u001b[97m\u001b[40m)\u001b[67C \u001b[7m|\u001b[13;3H\u001b[m\u000f\u001b[38;5;32m\u001b[48;5;234m 13 \u001b[97m\u001b[48;5;236m \u001b[40m   X = X + noise * torch.randn_like(X)\u001b[62C \u001b[7m|\u001b[14;3H\u001b[m\u000f\u001b[38;5;32m\u001b[48;5;234m 14 \u001b[97m\u001b[48;5;236m \u001b[40m   y = torch.cat([torch.zeros(n2), torch.ones(n2)])\u001b[49C \u001b[7m|\u001b[15;3H\u001b[m\u000f\u001b[38;5;32m\u001b[48;5;234m 15 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[93m\u001b[1mreturn\u001b[m\u000f\u001b[97m\u001b[40m X, y\u001b[86C \u001b[7m|\u001b[16;3H\u001b[m\u000f\u001b[38;5;32m\u001b[48;5;234m 16 \u001b[101C\u001b[97m\u001b[40m \u001b[7m|\u001b[17;3H\u001b[m\u000f\u001b[38;5;32m\u001b[48;5;234m 17 \u001b[101C\u001b[97m\u001b[40m \u001b[7m|\u001b[18;3H\u001b[m\u000f\u001b[38;5;32m\u001b[48;5;234m 18 \u001b[101C\u001b[97m\u001b[40m \u001b[7m|\u001b[19;3H\u001b[m\u000f\u001b[38;5;32m\u001b[48;5;234m 19 \u001b[93m\u001b[40m\u001b[1mclass\u001b[m\u000f\u001b[97m\u001b[40m \u001b[96m\u001b[1mMLP\u001b[m\u000f\u001b[97m\u001b[40m(nn.Module):\u001b[80C \u001b[7m|\u001b[20;3H\u001b[m\u000f\u001b[38;5;32m\u001b[48;5;234m 20 \u001b[97m\u001b[48;5;236m \u001b[40m \u001b[93m\u001b[1mdef\u001b[m\u000f\u001b[97m\u001b[40m \u001b[96m\u001b[1m__init__\u001b[m\u000f\u001b[97m\u001b[40m(self, in_dim=\u001b[38;5;217m\u001b[48;5;234m2\u001b[97m\u001b[40m, hidden=\u001b[38;5;217m\u001b[48;5;234m16\u001b[97m\u001b[40m, out_dim=\u001b[38;5;217m\u001b[48;5;234m1\u001b[97m\u001b[40m):\u001b[48C \u001b[7m|\u001b[21;3H\u001b[m\u000f\u001b[38;5;32m\u001b[48;5;234m 21 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[96m\u001b[1msuper\u001b[m\u000f\u001b[97m\u001b[40m().__init__()\u001b[79C \u001b[7m|\u001b[22;3H\u001b[m\u000f\u001b[38;5;32m\u001b[48;5;234m 22 \u001b[97m\u001b[48;5;236m \u001b[40m   self.net = nn.Sequential(\u001b[72C \u001b[7m|\u001b[23;3H\u001b[m\u000f\u001b[38;5;32m\u001b[48;5;234m 23 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m nn.Linear(in_dim, hidden),\u001b[m\u000f"]
[6.158295, "o", "\u001b[1;110H\u001b[38;5;159m\u001b[48;5;238m.\u001b[2;110H\u001b[40mp\u001b[3;110H\u001b[38;5;224m|\u001b[4;110H\u001b[38;5;81m\u001b[48;5;233m~\u001b[5;110H~\u001b[6;110H~\u001b[7;110H~\u001b[8;110H~\u001b[9;110H~\u001b[10;110H~\u001b[11;110H~\u001b[12;110H~\u001b[13;110H~\u001b[14;110H~\u001b[15;110H~\u001b[16;110H~\u001b[17;110H~\u001b[18;110H~\u001b[19;110H~\u001b[20;110H~\u001b[21;110H~\u001b[22;110H~\u001b[23;108H\u001b[97m\u001b[40m \u001b[7m|\u001b[m\u000f\u001b[38;5;81m\u001b[48;5;233m~\u001b[24;3H\u001b[38;5;32m\u001b[48;5;234m 24 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m nn.ReLU(),\u001b[85C \u001b[7m|\u001b[m\u000f\u001b[38;5;81m\u001b[48;5;233m~\u001b[25;3H\u001b[38;5;32m\u001b[48;5;234m 25 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m nn.Linear(hidden, hidden),\u001b[69C \u001b[7m|\u001b[m\u000f\u001b[38;5;81m\u001b[48;5;233m~\u001b[26;3H\u001b[38;5;32m\u001b[48;5;234m 26 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m nn.ReLU(),\u001b[85C \u001b[7m|\u001b[m\u000f\u001b[38;5;81m\u001b[48;5;233m~\u001b[27;3H\u001b[38;5;32m\u001b[48;5;234m 27 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m nn.Linear(hidden, out_dim),\u001b[68C \u001b[7m|\u001b[m\u000f\u001b[38;5;81m\u001b[48;5;233m~\u001b[28;3H\u001b[97m\u001b[48;5;238mmlp.py\u001b[100C \u001b[40m\u001b[7m<\u001b[1;7H\u001b[34h\u001b[?25h\u001b[m\u000f"]
[6.161195, "o", "\u001b[3G\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m  1 \u001b[38;5;207m\u001b[40m\u001b[1mimport\u001b[m\u000f\u001b[97m\u001b[40m time\u001b[2;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m  2 \u001b[38;5;207m\u001b[40m\u001b[1mimport\u001b[m\u000f\u001b[97m\u001b[40m torch\u001b[3;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m  3 \u001b[38;5;207m\u001b[40m\u001b[1mimport\u001b[m\u000f\u001b[97m\u001b[40m torch.nn  \u001b[93m\u001b[1mas\u001b[m\u000f\u001b[97m\u001b[40m  nn\u001b[4;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m  4 \u001b[5;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m  5 \u001b[6;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m  6 \u001b[7;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m  7 \u001b[93m\u001b[40m\u001b[1mdef\u001b[m\u000f\u001b[97m\u001b[40m \u001b[96m\u001b[1mmake_moons\u001b[m\u000f\u001b[97m\u001b[40m(n=\u001b[38;5;217m\u001b[48;5;234m400\u001b[97m\u001b[40m, noise=\u001b[38;5;217m\u001b[48;5;234m0.2\u001b[97m\u001b[40m):\u001b[8;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m  8 \u001b[97m\u001b[48;5;236m \u001b[40m   n2  =  n // \u001b[38;5;217m\u001b[48;5;234m2\u001b[9;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m  9 \u001b[97m\u001b[48;5;236m \u001b[40m   t = torch.linspace(\u001b[38;5;217m\u001b[48;5;234m0\u001b[97m\u001b[40m, \u001b[38;5;217m\u001b[48;5;234m3.14159\u001b[97m\u001b[40m, n2)\u001b[10;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 10 \u001b[97m\u001b[48;5;236m \u001b[40m   x1 = torch.stack([torch.cos(t), torch.sin(t)], dim=\u001b[38;5;217m\u001b[48;5;234m1\u001b[97m\u001b[40m)\u001b[11;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 11 \u001b[97m\u001b[48;5;236m \u001b[40m   x2 = torch.stack([\u001b[38;5;217m\u001b[48;5;234m1\u001b[97m\u001b[40m - torch.cos(t), \u001b[38;5;217m\u001b[48;5;234m1\u001b[97m\u001b[40m - torch.sin(t) - \u001b[38;5;217m\u001b[48;5;234m0.5\u001b[97m\u001b[40m], dim=\u001b[38;5;217m\u001b[48;5;234m1\u001b[97m\u001b[40m)\u001b[12;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 12 \u001b[97m\u001b[48;5;236m \u001b[40m   X = torch.cat([x1, x2], dim=\u001b[38;5;217m\u001b[48;5;234m0\u001b[97m\u001b[40m)\u001b[13;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 13 \u001b[97m\u001b[48;5;236m \u001b[40m   X = X + noise * torch.randn_like(X)\u001b[?25l\u001b[m\u000f"]
[6.162227, "o", "\u001b[14;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 14 \u001b[97m\u001b[48;5;236m \u001b[40m   y = torch.cat([torch.zeros(n2), torch.ones(n2)])\u001b[15;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 15 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[93m\u001b[1mreturn\u001b[m\u000f\u001b[97m\u001b[40m X, y\u001b[16;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 16 \u001b[17;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 17 \u001b[18;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 18 \u001b[19;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 19 \u001b[93m\u001b[40m\u001b[1mclass\u001b[m\u000f\u001b[97m\u001b[40m \u001b[96m\u001b[1mMLP\u001b[m\u000f\u001b[97m\u001b[40m(nn.Module):\u001b[20;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 20 \u001b[97m\u001b[48;5;236m \u001b[40m \u001b[93m\u001b[1mdef\u001b[m\u000f\u001b[97m\u001b[40m \u001b[96m\u001b[1m__init__\u001b[m\u000f\u001b[97m\u001b[40m(self, in_dim=\u001b[38;5;217m\u001b[48;5;234m2\u001b[97m\u001b[40m, hidden=\u001b[38;5;217m\u001b[48;5;234m16\u001b[97m\u001b[40m, out_dim=\u001b[38;5;217m\u001b[48;5;234m1\u001b[97m\u001b[40m):\u001b[21;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 21 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[96m\u001b[1msuper\u001b[m\u000f\u001b[97m\u001b[40m().__init__()\u001b[22;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 22 \u001b[97m\u001b[48;5;236m \u001b[40m   self.net = nn.Sequential(\u001b[23;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 23 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m nn.Linear(in_dim, hidden),\u001b[24;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 24 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m nn.ReLU(),\u001b[25;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 25 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m nn.Linear(hidden, hidden),\u001b[26;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 26 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m nn.ReLU(),\u001b[27;3H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 27 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m nn.Linear(hidden, out_dim),\u001b[1;9H\u001b[34h\u001b[?25h\u001b[m\u000f"]
