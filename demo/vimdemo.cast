[24.476444, "o", "\b\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m  1 \u001b[38;5;207m\u001b[40m\u001b[1mimport\u001b[m\u000f\u001b[97m\u001b[40m time                                                                      \u001b[7m|\u001b[2;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m  2 \u001b[97m\u001b[40m    \u001b[77C\u001b[7m|\u001b[3;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m  3 \u001b[38;5;207m\u001b[40m\u001b[1mimport\u001b[m\u000f\u001b[97m\u001b[40m torch\u001b[69C\u001b[7m|\u001b[4;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m  4 \u001b[38;5;207m\u001b[40m\u001b[1mimport\u001b[m\u000f\u001b[97m\u001b[40m torch.nn \u001b[93m\u001b[1mas\u001b[m\u000f\u001b[97m\u001b[40m nn                                                            \u001b[7m|\u001b[5;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m  5 \u001b[97m\u001b[40m                                                                                 \u001b[7m|\u001b[6;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m  6 \u001b[97m\u001b[40m                                                                                 \u001b[7m|\u001b[7;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m  7 \u001b[93m\u001b[40m\u001b[1mdef\u001b[m\u000f\u001b[97m\u001b[40m \u001b[96m\u001b[1mmake_moons\u001b[m\u000f\u001b[97m\u001b[40m(n=\u001b[38;5;217m\u001b[48;5;234m400\u001b[97m\u001b[40m, noise=\u001b[38;5;217m\u001b[48;5;234m0.2\u001b[97m\u001b[40m):                                                \u001b[7m|\u001b[8;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m  8 \u001b[97m\u001b[48;5;236m \u001b[40m   n2 = n // \u001b[38;5;217m\u001b[48;5;234m2\u001b[97m\u001b[40m                                                                  \u001b[7m|\u001b[9;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m  9 \u001b[97m\u001b[48;5;236m \u001b[40m   t = torch.linspace(\u001b[38;5;217m\u001b[48;5;234m0\u001b[97m\u001b[40m, \u001b[38;5;217m\u001b[48;5;234m3.14159\u001b[97m\u001b[40m, n2)                                           \u001b[7m|\u001b[10;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m 10 \u001b[97m\u001b[48;5;236m \u001b[40m   x1 = torch.stack([torch.cos(t), torch.sin(t)], dim=\u001b[38;5;217m\u001b[48;5;234m1\u001b[?25l\u001b[m\u000f"]
[24.47726, "o", "\u001b[97m\u001b[40m)                        \u001b[7m|\u001b[11;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m 11 \u001b[97m\u001b[48;5;236m \u001b[40m   x2 = torch.stack([\u001b[38;5;217m\u001b[48;5;234m1\u001b[97m\u001b[40m - torch.cos(t), \u001b[38;5;217m\u001b[48;5;234m1\u001b[97m\u001b[40m - torch.sin(t) - \u001b[38;5;217m\u001b[48;5;234m0.5\u001b[97m\u001b[40m], dim=\u001b[38;5;217m\u001b[48;5;234m1\u001b[97m\u001b[40m)          \u001b[7m|\u001b[12;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m 12 \u001b[97m\u001b[48;5;236m \u001b[40m   X = torch.cat([x1, x2], dim=\u001b[38;5;217m\u001b[48;5;234m0\u001b[97m\u001b[40m)                                               \u001b[7m|\u001b[13;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m 13 \u001b[97m\u001b[48;5;236m \u001b[40m   X = X + noise * torch.randn_like(X)                                          \u001b[7m|\u001b[14;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m 14 \u001b[97m\u001b[48;5;236m \u001b[40m   y = torch.cat([torch.zeros(n2), torch.ones(n2)])                             \u001b[7m|\u001b[15;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m 15 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[93m\u001b[1mreturn\u001b[m\u000f\u001b[97m\u001b[40m X, y                                                                  \u001b[7m|\u001b[16;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m 16 \u001b[97m\u001b[40m                                                                                 \u001b[7m|\u001b[17;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m 17 \u001b[97m\u001b[40m                                                                                 \u001b[7m|\u001b[18;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m 18 \u001b[93m\u001b[40m\u001b[1mclass\u001b[m\u000f\u001b[97m\u001b[40m \u001b[96m\u001b[1mMLP\u001b[m\u000f\u001b[97m\u001b[40m(nn.Module):                                                            \u001b[7m|\u001b[19;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m 19 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[93m\u001b[1mdef\u001b[m\u000f\u001b[97m\u001b[40m \u001b[96m\u001b[1m__init__\u001b[m\u000f\u001b[97m\u001b[40m(self, in_dim=\u001b[m\u000f"]
[24.478398, "o", "\u001b[38;5;217m\u001b[48;5;234m2\u001b[97m\u001b[40m, hidden=\u001b[38;5;217m\u001b[48;5;234m16\u001b[97m\u001b[40m, out_dim=\u001b[38;5;217m\u001b[48;5;234m1\u001b[97m\u001b[40m):                          \u001b[7m|\u001b[20;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m 20 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m   \u001b[96m\u001b[1msuper\u001b[m\u000f\u001b[97m\u001b[40m().__init__()                                                       \u001b[7m|\u001b[21;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m 21 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m   self.net = nn.Sequential(                                                \u001b[7m|\u001b[22;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m 22 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m   \u001b[48;5;236m \u001b[40m   nn.Linear(in_dim, hidden),                                           \u001b[7m|\u001b[23;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m 23 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m   \u001b[48;5;236m \u001b[40m   nn.ReLU(),                                                           \u001b[7m|\u001b[24;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m 24 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m   \u001b[48;5;236m \u001b[40m   nn.Linear(hidden, hidden),                                           \u001b[7m|\u001b[25;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m 25 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m   \u001b[48;5;236m \u001b[40m   nn.ReLU(),                                                           \u001b[7m|\u001b[26;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m 26 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m   \u001b[48;5;236m \u001b[40m   nn.Linear(hidden, out_dim),                                          \u001b[7m|\u001b[27;4H\u001b[m\u000f\u001b[30m\u001b[107m \u001b[38;5;32m\u001b[48;5;234m 27 \u001b[97m\u001b[48;5;236m \u001b[m\u000f"]
