[2.655293, "o", "\u001b[H\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m  1 \u001b[38;5;207m\u001b[40m\u001b[1mimport\u001b[m\u000f\u001b[97m\u001b[40m time\r\n\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m  2 \u001b[38;5;207m\u001b[40m\u001b[1mimport\u001b[m\u000f\u001b[97m\u001b[40m torch\r\n\u001b[30m\u001b[103mW \u001b[38;5;32m\u001b[48;5;234m  3 \u001b[38;5;207m\u001b[40m\u001b[1mimport\u001b[m\u000f\u001b[97m\u001b[40m torch.nn\u001b[104m  \u001b[93m\u001b[1mas\u001b[m\u000f\u001b[97m\u001b[104m  nn\u001b[38;5;63m\u001b[40m\u001b[1m # W: E272 multiple spaces before keyword\r\n\u001b[m\u000f\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m  4 \r\n\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m  5 \r\n\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m  6 \r\n\u001b[30m\u001b[103mW \u001b[38;5;32m\u001b[48;5;234m  7 \u001b[93m\u001b[104m\u001b[1mdef\u001b[m\u000f\u001b[97m\u001b[104m \u001b[96m\u001b[1mmake_moons\u001b[m\u000f\u001b[97m\u001b[104m(n=\u001b[38;5;217m400\u001b[97m, noise=\u001b[38;5;217m0.2\u001b[97m):\u001b[38;5;63m\u001b[40m\u001b[1m # W: E303 too many blank lines (3)\r\n\u001b[m\u000f\u001b[30m\u001b[103mW \u001b[38;5;32m\u001b[48;5;234m  8 \u001b[97m\u001b[48;5;236m \u001b[40m   n2\u001b[104m  =  n // \u001b[38;5;217m2\u001b[38;5;63m\u001b[40m\u001b[1m # W: E221 multiple spaces before operator\r\n\u001b[m\u000f\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m  9 \u001b[97m\u001b[48;5;236m \u001b[40m   t = torch.linspace(\u001b[38;5;217m\u001b[48;5;234m0\u001b[97m\u001b[40m, \u001b[38;5;217m\u001b[48;5;234m3.14159\u001b[97m\u001b[40m, n2)\r\n\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 10 \u001b[97m\u001b[48;5;236m \u001b[40m   x1 = torch.stack([torch.cos(t), torch.sin(t)], dim=\u001b[38;5;217m\u001b[48;5;234m1\u001b[97m\u001b[40m)\r\n\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 11 \u001b[97m\u001b[48;5;236m \u001b[40m   x2 = torch.stack([\u001b[38;5;217m\u001b[48;5;234m1\u001b[97m\u001b[40m - torch.cos(t), \u001b[38;5;217m\u001b[48;5;234m1\u001b[97m\u001b[40m - torch.sin(t) - \u001b[38;5;217m\u001b[48;5;234m0.5\u001b[97m\u001b[40m], dim=\u001b[38;5;217m\u001b[48;5;234m1\u001b[?25l\u001b[m\u000f"]
[2.656622, "o", "\u001b[97m\u001b[40m)\r\n\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 12 \u001b[97m\u001b[48;5;236m \u001b[40m   X = torch.cat([x1, x2], dim=\u001b[38;5;217m\u001b[48;5;234m0\u001b[97m\u001b[40m)\r\n\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 13 \u001b[97m\u001b[48;5;236m \u001b[40m   X = X + noise * torch.randn_like(X)\r\n\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 14 \u001b[97m\u001b[48;5;236m \u001b[40m   y = torch.cat([torch.zeros(n2), torch.ones(n2)])\r\n\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 15 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[93m\u001b[1mreturn\u001b[m\u000f\u001b[97m\u001b[40m X, y\r\n\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 16 \r\n\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 17 \r\n\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 18 \r\n\u001b[30m\u001b[103mW \u001b[38;5;32m\u001b[48;5;234m 19 \u001b[93m\u001b[104m\u001b[1mclass\u001b[m\u000f\u001b[97m\u001b[104m \u001b[96m\u001b[1mMLP\u001b[m\u000f\u001b[97m\u001b[104m(nn.Module):\u001b[38;5;63m\u001b[40m\u001b[1m # W: E303 too many blank lines (3)\r\n\u001b[m\u000f\u001b[30m\u001b[103mW \u001b[38;5;32m\u001b[48;5;234m 20 \u001b[97m\u001b[48;5;236m \u001b[40m \u001b[93m\u001b[104m\u001b[1mdef\u001b[m\u000f\u001b[97m\u001b[104m \u001b[96m\u001b[1m__init__\u001b[m\u000f\u001b[97m\u001b[104m(self, in_dim=\u001b[38;5;217m2\u001b[97m, hidden=\u001b[38;5;217m16\u001b[97m, out_dim=\u001b[38;5;217m1\u001b[97m):\u001b[38;5;63m\u001b[40m\u001b[1m # W: E111 indentation is not a multiple of 4\r\n\u001b[m\u000f\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 21 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[96m\u001b[1msuper\u001b[m\u000f\u001b[97m\u001b[40m().__init__()\r\n\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 22 \u001b[97m\u001b[48;5;236m \u001b[40m   self.net = nn.Sequential(\r\n\u001b[30m\u001b[103mW \u001b[38;5;32m\u001b[48;5;234m 23 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m \u001b[104mnn.Linear(in_dim, hidden),\u001b[38;5;63m\u001b[40m\u001b[1m # W: E121 continuation line under-indented for hanging indent\u001b[m\u000f"]
[2.65698, "o", "\r\n\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 24 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m nn.ReLU(),\r\n\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 25 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m nn.Linear(hidden, hidden),\r\n\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 26 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m nn.ReLU(),\r\n\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 27 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m nn.Linear(hidden, out_dim),\r\n\u001b[30m\u001b[107m  \u001b[38;5;32m\u001b[48;5;234m 28 \u001b[97m\u001b[48;5;236m \u001b[40m   )\u001b[1;7H\u001b[34h\u001b[?25h\u001b[m\u000f"]
