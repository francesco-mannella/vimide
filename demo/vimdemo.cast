[0.326174, "o", "\u001b[38;5;32m\u001b[48;5;234m  1 \u001b[38;5;207m\u001b[40m\u001b[1mimport\u001b[m\u000f\u001b[97m\u001b[40m time                                                                                               \u001b[2;1H\u001b[38;5;32m\u001b[48;5;234m  2 \u001b[38;5;207m\u001b[40m\u001b[1mimport\u001b[m\u000f\u001b[97m\u001b[40m torch                                                                                              \u001b[3;1H\u001b[38;5;32m\u001b[48;5;234m  3 \u001b[38;5;207m\u001b[40m\u001b[1mimport\u001b[m\u000f\u001b[97m\u001b[40m torch.nn  \u001b[93m\u001b[1mas\u001b[m\u000f\u001b[97m\u001b[40m  nn                                                                                   \u001b[4;1H\u001b[38;5;32m\u001b[48;5;234m  4 \u001b[97m\u001b[40m                                                                                                          \u001b[5;1H\u001b[38;5;32m\u001b[48;5;234m  5 \u001b[97m\u001b[40m                                                                                                          \u001b[6;1H\u001b[38;5;32m\u001b[48;5;234m  6 \u001b[97m\u001b[40m                                                                                                          \u001b[7;1H\u001b[38;5;32m\u001b[48;5;234m  7 \u001b[93m\u001b[40m\u001b[1mdef\u001b[m\u000f\u001b[97m\u001b[40m \u001b[96m\u001b[1mmake_moons\u001b[m\u000f\u001b[97m\u001b[40m(n=\u001b[38;5;217m\u001b[48;5;234m400\u001b[97m\u001b[40m, noise=\u001b[38;5;217m\u001b[48;5;234m0.2\u001b[97m\u001b[40m):                                                                         \u001b[8;1H\u001b[38;5;32m\u001b[48;5;234m  8 \u001b[97m\u001b[48;5;236m \u001b[40m   n2  =  n // \u001b[38;5;217m\u001b[48;5;234m2\u001b[97m\u001b[40m                                                                                         \u001b[9;1H\u001b[38;5;32m\u001b[48;5;234m  9 \u001b[97m\u001b[48;5;236m \u001b[40m   t = torch.linspace(\u001b[38;5;217m\u001b[48;5;234m0\u001b[97m\u001b[40m, \u001b[38;5;217m\u001b[48;5;234m3.14159\u001b[97m\u001b[40m, n2)                                                                    \u001b[10;1H\u001b[38;5;32m\u001b[48;5;234m 10 \u001b[97m\u001b[48;5;236m \u001b[40m   x1 = torch.stack([torch.cos(t), torch.sin(t)], dim=\u001b[38;5;217m\u001b[48;5;234m1\u001b[97m\u001b[40m)                                                 \u001b[?25l\u001b[m\u000f"]
[0.326834, "o", "\u001b[11;1H\u001b[38;5;32m\u001b[48;5;234m 11 \u001b[97m\u001b[48;5;236m \u001b[40m   x2 = torch.stack([\u001b[38;5;217m\u001b[48;5;234m1\u001b[97m\u001b[40m - torch.cos(t), \u001b[38;5;217m\u001b[48;5;234m1\u001b[97m\u001b[40m - torch.sin(t) - \u001b[38;5;217m\u001b[48;5;234m0.5\u001b[97m\u001b[40m], dim=\u001b[38;5;217m\u001b[48;5;234m1\u001b[97m\u001b[40m)                                   \u001b[12;1H\u001b[38;5;32m\u001b[48;5;234m 12 \u001b[97m\u001b[48;5;236m \u001b[40m   X = torch.cat([x1, x2], dim=\u001b[38;5;217m\u001b[48;5;234m0\u001b[97m\u001b[40m)                                                                        \u001b[13;1H\u001b[38;5;32m\u001b[48;5;234m 13 \u001b[97m\u001b[48;5;236m \u001b[40m   X = X + noise * torch.randn_like(X)                                                                   \u001b[14;1H\u001b[38;5;32m\u001b[48;5;234m 14 \u001b[97m\u001b[48;5;236m \u001b[40m   y = torch.cat([torch.zeros(n2), torch.ones(n2)])                                                      \u001b[15;1H\u001b[38;5;32m\u001b[48;5;234m 15 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[93m\u001b[1mreturn\u001b[m\u000f\u001b[97m\u001b[40m X, y                                                                                           \u001b[16;1H\u001b[38;5;32m\u001b[48;5;234m 16 \u001b[97m\u001b[40m                                                                                                          \u001b[17;1H\u001b[38;5;32m\u001b[48;5;234m 17 \u001b[97m\u001b[40m                                                                                                          \u001b[18;1H\u001b[38;5;32m\u001b[48;5;234m 18 \u001b[97m\u001b[40m                                                                                                          \u001b[19;1H\u001b[38;5;32m\u001b[48;5;234m 19 \u001b[93m\u001b[40m\u001b[1mclass\u001b[m\u000f\u001b[97m\u001b[40m \u001b[96m\u001b[1mMLP\u001b[m\u000f\u001b[97m\u001b[40m(nn.Module):                                                                                     \u001b[20;1H\u001b[38;5;32m\u001b[48;5;234m 20 \u001b[97m\u001b[48;5;236m \u001b[40m \u001b[93m\u001b[1mdef\u001b[m\u000f\u001b[97m\u001b[40m \u001b[96m\u001b[1m__init__\u001b[m\u000f\u001b[97m\u001b[40m(self, in_dim=\u001b[38;5;217m\u001b[48;5;234m2\u001b[97m\u001b[40m, hidden=\u001b[38;5;217m\u001b[48;5;234m16\u001b[97m\u001b[40m, out_dim=\u001b[m\u000f"]
[0.327587, "o", "\u001b[38;5;217m\u001b[48;5;234m1\u001b[97m\u001b[40m):                                                     \u001b[21;1H\u001b[38;5;32m\u001b[48;5;234m 21 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[96m\u001b[1msuper\u001b[m\u000f\u001b[97m\u001b[40m().__init__()                                                                                    \u001b[22;1H\u001b[38;5;32m\u001b[48;5;234m 22 \u001b[97m\u001b[48;5;236m \u001b[40m   self.net = nn.Sequential(                                                                             \u001b[23;1H\u001b[38;5;32m\u001b[48;5;234m 23 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m nn.Linear(in_dim, hidden),                                                                          \u001b[24;1H\u001b[38;5;32m\u001b[48;5;234m 24 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m nn.ReLU(),                                                                                          \u001b[25;1H\u001b[38;5;32m\u001b[48;5;234m 25 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m nn.Linear(hidden, hidden),                                                                          \u001b[26;1H\u001b[38;5;32m\u001b[48;5;234m 26 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m nn.ReLU(),                                                                                          \u001b[27;1H\u001b[38;5;32m\u001b[48;5;234m 27 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[48;5;234m \u001b[40m nn.Linear(hidden, out_dim),                                                                         \u001b[28;1H\u001b[38;5;32m\u001b[48;5;234m 28 \u001b[97m\u001b[48;5;236m \u001b[40m   )                                                                                                     \u001b[1;5H\u001b[34h\u001b[?25h\u001b[m\u000f"]
