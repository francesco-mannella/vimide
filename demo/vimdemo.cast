           \u001b[30m\u001b[107m\u001b[15;1H  \u001b[38;5;32m\u001b[48;5;234m 15 \u001b[97m\u001b[48;5;236m \u001b[40m   \u001b[93m\u001b[1mreturn\u001b[m\u000f\u001b[97m\u001b[40m X, y                                                                                         \u001b[30m\u001b[107m\u001b[16;1H  \u001b[38;5;32m\u001b[48;5;234m 16 \u001b[97m\u001b[40m                                                                                                        \u001b[30m\u001b[107m\u001b[17;1H  \u001b[38;5;32m\u001b[48;5;234m 17 \u001b[97m\u001b[40m                                                                                                        \u001b[30m\u001b[107m\u001b[18;1H  \u001b[38;5;32m\u001b[48;5;234m 18 \u001b[97m\u001b[40m                                                                                                        \u001b[30m\u001b[103m\u001b[19;1HW \u001b[38;5;32m\u001b[48;5;234m 19 \u001b[93m\u001b[104m\u001b[1mclass\u001b[m\u000f\u001b[97m\u001b[104m \u001b[96m\u001b[1mMLP\u001b[m\u000f\u001b[97m\u001b[104m(nn.Module):\u001b[38;5;63m\u001b[40m\u001b[1m # W: E303 too many blank lines (3)\u001b[m\u000f\u001b[97m\u001b[40m                                    "]
