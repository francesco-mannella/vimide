#!/usr/bin/env python3
import subprocess, sys, textwrap, curses

col_w  = int(sys.argv[1]) if len(sys.argv) > 1 else 14
desc_w = int(sys.argv[2]) if len(sys.argv) > 2 else 60

# ── git data ───────────────────────────────────────────────────────────────────
raw_refs = subprocess.check_output(
    ["git", "for-each-ref",
     "--format=%(refname:short)\t%(committerdate:unix)",
     "refs/heads/", "refs/remotes/"],
    text=True,
).strip().splitlines()
raw_refs = [ln for ln in raw_refs if not ln.startswith("origin/HEAD\t")]
branches = [
    ln.split("\t")[0]
    for ln in sorted(raw_refs, key=lambda l: int(l.split("\t")[1]))
]

PAIRS = [1, 2, 3, 4, 5, 6]
col_pair = {b: PAIRS[i % len(PAIRS)] for i, b in enumerate(branches)}

def git_log(ref, fmt):
    out = subprocess.check_output(
        ["git", "log", "--format=" + fmt, ref], text=True
    ).splitlines()
    out.reverse()
    return out

branch_commits = {b: git_log(b, "%h") for b in branches}

all_commits = subprocess.check_output(
    ["git", "log", "--format=%h", "--all", "--topo-order"], text=True
).split()
all_commits.reverse()

subjects = {}
for line in subprocess.check_output(
    ["git", "log", "--format=%h\t%s", "--all"], text=True
).splitlines():
    h, _, s = line.partition("\t")
    subjects[h.strip()] = s.strip()

commit_branch = {}
for b in branches:
    for h in branch_commits[b]:
        commit_branch.setdefault(h, b)

parents = {}
for line in subprocess.check_output(
    ["git", "log", "--format=%h\t%p", "--all"], text=True
).splitlines():
    h, _, p = line.partition("\t")
    parents[h.strip()] = p.strip().split() if p.strip() else []

annotations = {}
for b in branches:
    for h in branch_commits[b]:
        if commit_branch.get(h) != b:
            continue
        for par in parents.get(h, []):
            orig = commit_branch.get(par)
            if orig and orig != b:
                annotations[h] = (False, orig)
        break

for h, ps in parents.items():
    if len(ps) >= 2:
        orig = commit_branch.get(ps[1])
        if orig and orig != commit_branch.get(h):
            annotations[h] = (True, orig)

widths   = [max(col_w, len(b) + 2) for b in branches]
total_w  = sum(widths)

# ── curses ─────────────────────────────────────────────────────────────────────
def draw_segs(win, y, segments, sx):
    _, win_w = win.getmaxyx()
    xpos = screen_x = 0
    for text, attr in segments:
        for ch in text:
            if xpos >= sx:
                if screen_x >= win_w - 1:
                    return
                try:
                    win.addch(y, screen_x, ch, attr)
                except curses.error:
                    pass
                screen_x += 1
            xpos += 1

def main(stdscr):
    curses.start_color()
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_CYAN,    -1)
    curses.init_pair(2, curses.COLOR_YELLOW,  -1)
    curses.init_pair(3, curses.COLOR_GREEN,   -1)
    curses.init_pair(4, curses.COLOR_MAGENTA, -1)
    curses.init_pair(5, curses.COLOR_BLUE,    -1)
    curses.init_pair(6, curses.COLOR_RED,     -1)
    curses.curs_set(0)
    stdscr.keypad(True)

    # header segments (pinned)
    hdr = [(f"{b:<{w}}", curses.color_pair(col_pair[b]) | curses.A_BOLD)
           for b, w in zip(branches, widths)]
    hdr.append(("description", curses.A_BOLD))

    sep_text = "┬".join("─" * w for w in widths) + "┬" + "─" * desc_w
    sep = [(sep_text, 0)]

    # content rows
    rows = []
    for h in all_commits:
        owner = commit_branch.get(h)
        if owner is None:
            continue
        pair = curses.color_pair(col_pair[owner])

        ann = annotations.get(h)
        if ann:
            is_merge, orig = ann
            ann_segs = []
            for b, w in zip(branches, widths):
                if b == owner:
                    break
                ann_segs.append((" " * w, 0))
            arrow = "╭─ merge ← " if is_merge else "╭─ ← "
            orig_attr = curses.color_pair(col_pair[orig]) | curses.A_BOLD if orig in col_pair else curses.A_BOLD
            ann_segs.append((arrow, curses.A_DIM | pair))
            ann_segs.append((orig,  orig_attr))
            rows.append(ann_segs)

        row = []
        for b, w in zip(branches, widths):
            if b == owner:
                row.append((f"{'● ' + h:<{w}}", pair))
            else:
                row.append((" " * w, 0))
        wrapped = textwrap.wrap(subjects.get(h, ""), desc_w) or [""]
        row.append((wrapped[0], 0))
        rows.append(row)
        for cont in wrapped[1:]:
            rows.append([(" " * total_w, 0), (cont, 0)])

    sy = sx = 0

    while True:
        win_h, _ = stdscr.getmaxyx()
        visible  = win_h - 2
        max_sy   = max(0, len(rows) - visible)
        stdscr.erase()

        draw_segs(stdscr, 0, hdr, sx)
        draw_segs(stdscr, 1, sep, sx)
        for i, segs in enumerate(rows[sy:sy + visible]):
            draw_segs(stdscr, i + 2, segs, sx)

        stdscr.refresh()

        key = stdscr.getch()
        if key in (ord('q'), ord('Q'), 27):
            break
        elif key in (curses.KEY_DOWN,  ord('j')): sy = min(sy + 1,       max_sy)
        elif key in (curses.KEY_UP,    ord('k')): sy = max(sy - 1,       0)
        elif key == curses.KEY_NPAGE:             sy = min(sy + visible,  max_sy)
        elif key == curses.KEY_PPAGE:             sy = max(sy - visible,  0)
        elif key in (curses.KEY_HOME,  ord('g')): sy = 0
        elif key in (curses.KEY_END,   ord('G')): sy = max_sy
        elif key in (curses.KEY_RIGHT, ord('l')): sx += 4
        elif key in (curses.KEY_LEFT,  ord('h')): sx = max(sx - 4, 0)

curses.wrapper(main)
